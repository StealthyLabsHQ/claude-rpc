{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude RPC",
  "version": "3.1.1",
  "identifier": "eu.stealthylabs.claude-rpc",
  "mainBinaryName": "claude-rpc",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude RPC Settings",
        "width": 790,
        "height": 920,
        "minWidth": 680,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../logo/anthropic-rpc.ico"]
  }
}
